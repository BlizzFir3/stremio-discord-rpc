{
  "name": "stremio-discord-rpc",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format cjs --clean",
    "package": "npm run build && pkg . --targets node18-win-x64 --output bin/stremio-rpc.exe",
    "postpackage": "copy scripts\\*.bat bin\\"
  },
  "pkg": {
    "assets": [
      "icon.ico",
      "node_modules/systray2/traybin/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.3.1",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^25.4.0",
    "pkg": "^5.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}